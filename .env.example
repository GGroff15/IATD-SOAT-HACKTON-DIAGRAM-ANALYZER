# Required
S3_BUCKET_NAME=your-diagram-bucket

# AWS configuration
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=

# Optional AWS credentials (useful for LocalStack/local testing)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# API configuration
API_HOST=0.0.0.0
API_PORT=8000

# YOLO detection configuration
YOLO_MODEL_NAME=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_DEVICE=cpu

# PaddleOCR configuration
PADDLE_OCR_LANG=en
PADDLE_OCR_DEVICE=cpu
PADDLE_OCR_USE_ANGLE_CLS=true
PADDLE_OCR_MODEL_DIR=
PADDLE_OCR_ENABLE_MKLDNN=false
